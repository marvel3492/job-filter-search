{
    "manifest_version": 3,
    "name": "Job Filter Search",
    "version": "1.1.4",
    "description": "Custom search filters for Handshake and LinkedIn job listings.",
    "content_scripts": [
        {
            "matches": ["https://*.joinhandshake.com/job-search/*", "https://www.linkedin.com/jobs/collections/recommended/*"],
            "js": ["utils.js", "content.js"],
            "css": ["styles.css"]
        }
    ],
    "permissions": ["storage"],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {}
}